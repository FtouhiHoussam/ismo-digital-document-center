# MongoDB connection string
# Local default (matches the fallback in config/db.js):
MONGO_URI=mongodb://127.0.0.1:27017/ismo_digital

# JWT secret — change this to a long random string in production
JWT_SECRET=ismo-digital-secret-key-2024

# Server port
PORT=5000

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:5173

# Admin seed credentials (used by seed.js)
ADMIN_EMAIL=admin@ismo.ma
ADMIN_PASSWORD=admin123
